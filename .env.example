# ----- Unlink (https://dashboard.unlink.xyz) -----
# API key serveur (admin) — depuis le dashboard projet Unlink
UNLINK_API_KEY=

# Environnement Unlink: base-sepolia | arc-testnet | ethereum-sepolia | monad-testnet
UNLINK_ENVIRONMENT=base-sepolia

# Adresse du token de test (ERC-20) configuré pour l'environnement (ex: USDC test base-sepolia)
UNLINK_TEST_TOKEN=
# Décimales du token (USDC test = 6)
UNLINK_TOKEN_DECIMALS=6

# ----- Wallet (secret principal) -----
# UNE mnemonic BIP-39 dérive À LA FOIS le compte Unlink (shielded) ET le wallet EVM.
# Doit avoir un peu d'ETH base-sepolia pour le gas (approval/deposit/withdraw).
# Utiliser un wallet jetable.
WALLET_MNEMONIC=

# Optionnel: override de la clé privée EVM (utilisée seulement pour le wallet onchain).
# Si vide, le wallet EVM est dérivé de WALLET_MNEMONIC.
WALLET_PRIVATE_KEY=

# RPC base-sepolia (public par défaut)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ----- Déploiement / "bring your own bot" (per-user auth) -----
# URL publique de l'app déployée — affichée dans le snippet "connect your bot".
# Optionnel en local; requis en prod (Vercel).
NEXT_PUBLIC_SHADE_APP_URL=

# Pour faire tourner un bot externe en MODE REMOTE (sans clé admin):
#   SHADE_API_URL = l'URL de l'app déployée (ou http://localhost:3001 en local)
#   BOT_WALLET_PRIVATE_KEY = la clé privée du wallet du bot (self-custody)
# Laisser vides pour le mode local (clé admin) utilisé par les scripts internes.
SHADE_API_URL=
BOT_WALLET_PRIVATE_KEY=

# ----- Demo DeFi venues (/spy : l'agent alloue son capital) -----
# Déployés via `npx tsx scripts/deploy-mock-vault.ts` puis `npx tsx scripts/deploy-mocks.ts`.
# Si absents, la démo retombe sur les seuls paiements oracle (pas de phase d'allocation).
DEFI_VAULT_ADDRESS=
DEFI_SWAP_ROUTER=
DEFI_SWAP_QUOTER=
DEFI_SWAP_TOKENOUT=
DEFI_SWAP_FEE=3000
DEFI_AAVE_POOL=
DEFI_AAVE_ATOKEN=
