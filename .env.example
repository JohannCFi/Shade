# ----- Unlink (https://dashboard.unlink.xyz) -----
# API key serveur (admin) — depuis le dashboard projet Unlink
UNLINK_API_KEY=

# Environnement Unlink: base-sepolia | arc-testnet | ethereum-sepolia | monad-testnet
UNLINK_ENVIRONMENT=base-sepolia

# Adresse du token de test (ERC-20) configuré pour l'environnement (ex: USDC test base-sepolia)
UNLINK_TEST_TOKEN=
# Décimales du token (USDC test = 6)
UNLINK_TOKEN_DECIMALS=6

# ----- Wallet (secret principal) -----
# UNE mnemonic BIP-39 dérive À LA FOIS le compte Unlink (shielded) ET le wallet EVM.
# Doit avoir un peu d'ETH base-sepolia pour le gas (approval/deposit/withdraw).
# Utiliser un wallet jetable.
WALLET_MNEMONIC=

# Optionnel: override de la clé privée EVM (utilisée seulement pour le wallet onchain).
# Si vide, le wallet EVM est dérivé de WALLET_MNEMONIC.
WALLET_PRIVATE_KEY=

# RPC base-sepolia (public par défaut)
BASE_SEPOLIA_RPC=https://sepolia.base.org
